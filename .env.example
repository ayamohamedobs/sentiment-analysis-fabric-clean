# Copy and fill in, then: source .env (bash) or load with python-dotenv
# All auth uses managed identity (DefaultAzureCredential) – no API keys needed
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services-name>.cognitiveservices.azure.com/
AZURE_LANGUAGE_ENDPOINT=https://<your-language-name>.cognitiveservices.azure.com/
FOUNDRY_PROJECT_NAME=sentiment-analysis
GPT_DEPLOYMENT_NAME=gpt-4o

# Application Insights for monitoring and telemetry (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# Microsoft Fabric Data Agent (optional - for querying semantic models)
# Create a "Microsoft Fabric" connection in Foundry portal → Management Center → Connected Resources
# then set the connection name here. Leave empty to disable Fabric integration.
FABRIC_CONNECTION_NAME=

# Data source: 'local' (default) — user can switch to Fabric in UI when FABRIC_CONNECTION_NAME is set
DATA_SOURCE=local
