{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "enableFabric": {
      "value": "${AZURE_ENABLE_FABRIC=false}"
    },
    "fabricWorkspaceId": {
      "value": "${AZURE_FABRIC_WORKSPACE_ID=}"
    },
    "fabricArtifactId": {
      "value": "${AZURE_FABRIC_ARTIFACT_ID=}"
    },
    "fabricAdminEmail": {
      "value": "${AZURE_FABRIC_ADMIN_EMAIL=}"
    }
  }
}
